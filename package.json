    "express": "^5.2.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@vitest/ui": "^4.1.9",
    "vitest": "^4.1.9"
