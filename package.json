{
  "name": "clinicaltrials-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for ClinicalTrials.gov API",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "inline-ui": "node scripts/inline-ui.mjs",
    "prebuild": "node scripts/inline-ui.mjs",
